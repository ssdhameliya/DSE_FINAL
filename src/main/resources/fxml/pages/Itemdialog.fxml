<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ItemDialogController"
            prefWidth="850"
            prefHeight="650">

    <top>

        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:#2E7D32;
                     -fx-padding:15;">

            <Label text="📦 Add New Item"
                   style="-fx-text-fill:white;
                          -fx-font-size:22;
                          -fx-font-weight:bold;"/>

        </HBox>

    </top>

    <center>

        <ScrollPane fitToWidth="true">

            <GridPane hgap="15"
                      vgap="12"
                      style="-fx-padding:20;">

                <columnConstraints>

                    <ColumnConstraints percentWidth="25"/>

                    <ColumnConstraints percentWidth="25"/>

                    <ColumnConstraints percentWidth="25"/>

                    <ColumnConstraints percentWidth="25"/>

                </columnConstraints>

                <!-- Row 1 -->

                <Label text="Item Code"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtItemCode"
                           editable="false"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="Category"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="2"/>

                <ComboBox fx:id="cmbCategory"
                          GridPane.rowIndex="0"
                          GridPane.columnIndex="3"/>

                <!-- Row 2 -->

                <Label text="Description"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtDescription"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <Label text="Brand"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="2"/>

                <TextField fx:id="txtBrand"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="3"/>

                <!-- Row 3 -->

                <Label text="Material"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cmbMaterial"
                          GridPane.rowIndex="2"
                          GridPane.columnIndex="1"/>

                <Label text="Size"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="2"/>

                <TextField fx:id="txtSize"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="3"/>

                <!-- Row 4 -->

                <Label text="Unit"
                       GridPane.rowIndex="3"
                       GridPane.columnIndex="0"/>

                <ComboBox fx:id="cmbUnit"
                          GridPane.rowIndex="3"
                          GridPane.columnIndex="1"/>

                <Label text="HSN Code"
                       GridPane.rowIndex="3"
                       GridPane.columnIndex="2"/>

                <TextField fx:id="txtHSN"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="3"/>

                <!-- Row 5 -->

                <Label text="GST %"
                       GridPane.rowIndex="4"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtGST"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>

                <Label text="Purchase Price"
                       GridPane.rowIndex="4"
                       GridPane.columnIndex="2"/>

                <TextField fx:id="txtPurchasePrice"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="3"/>

                <!-- Row 6 -->

                <Label text="Selling Price"
                       GridPane.rowIndex="5"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtSellingPrice"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="1"/>

                <Label text="Opening Stock"
                       GridPane.rowIndex="5"
                       GridPane.columnIndex="2"/>

                <TextField fx:id="txtOpeningStock"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="3"/>

                <!-- Row 7 -->

                <Label text="Minimum Stock"
                       GridPane.rowIndex="6"
                       GridPane.columnIndex="0"/>

                <TextField fx:id="txtMinimumStock"
                           GridPane.rowIndex="6"
                           GridPane.columnIndex="1"/>

                <Label text="Rack Location"
                       GridPane.rowIndex="6"
                       GridPane.columnIndex="2"/>

                <TextField fx:id="txtLocation"
                           GridPane.rowIndex="6"
                           GridPane.columnIndex="3"/>

                <!-- Row 8 -->

                <Label text="Remarks"
                       GridPane.rowIndex="7"
                       GridPane.columnIndex="0"/>

                <TextArea fx:id="txtRemarks"
                          prefRowCount="4"
                          GridPane.rowIndex="7"
                          GridPane.columnIndex="1"
                          GridPane.columnSpan="3"/>

            </GridPane>

        </ScrollPane>

    </center>

    <bottom>

        <HBox alignment="CENTER_RIGHT"
              spacing="15"
              style="-fx-padding:15;">

            <Button fx:id="btnSave"
                    text="💾 Save"
                    onAction="#saveItem"/>

            <Button fx:id="btnCancel"
                    text="❌ Cancel"
                    onAction="#closeDialog"/>

        </HBox>

    </bottom>

</BorderPane>