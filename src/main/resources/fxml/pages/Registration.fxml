<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.RegistrationController" stylesheets="@../../css/login.css">
    <center>
        <VBox alignment="CENTER" spacing="12" styleClass="login-panel" maxWidth="430">
            <padding>
                <Insets top="45" right="50" bottom="45" left="50"/>
            </padding>
            <Label text="Create User Account" styleClass="login-title"/>
            <Label text="New accounts receive USER access. Email verification is required." wrapText="true"/>
            <TextField fx:id="txtName" promptText="Full name"/>
            <TextField fx:id="txtUsername" promptText="Username"/>
            <TextField fx:id="txtEmail" promptText="Email address"/>
            <PasswordField fx:id="txtPassword" promptText="Password"/>
            <PasswordField fx:id="txtConfirm" promptText="Confirm password"/>
            <Button text="Send email OTP" onAction="#sendOtp" prefWidth="250"/>
            <TextField fx:id="txtOtp" promptText="Enter OTP"/>
            <Button text="Create verified account" onAction="#register" prefWidth="250"/>
            <Hyperlink text="Back to login" onAction="#back"/>
            <Label fx:id="lblMessage" wrapText="true"/>
        </VBox>
    </center>
</BorderPane>
