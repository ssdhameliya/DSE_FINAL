<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ItemMasterController">

    <!-- ========================= TOP ========================= -->

    <top>

        <VBox spacing="15" style="-fx-padding:20;">

            <HBox alignment="CENTER_LEFT" spacing="15">

                <Label text="📦 Item Master"
                       style="-fx-font-size:24px;
                              -fx-font-weight:bold;"/>

                <Pane HBox.hgrow="ALWAYS"/>

                <TextField fx:id="txtSearch"
                           promptText="Search Item..."
                           prefWidth="250"/>

            </HBox>

            <HBox spacing="10">

                <Button text="➕ New Item"
                        onAction="#newItem"/>

                <Button text="✏ Edit" onAction="#editItem"/>

                <Button text="🗑 Delete" onAction="#deleteItem"/>

                <Button text="🔄 Refresh" onAction="#refresh"/>

                <Button text="📥 Import" onAction="#importItems"/>

                <Button text="📤 Export" onAction="#exportItems"/>

            </HBox>

        </VBox>

    </top>

    <!-- ========================= CENTER ========================= -->

    <center>

        <TableView fx:id="tableItems"
                   VBox.vgrow="ALWAYS">

            <columns>

                <TableColumn fx:id="colCode"
                             text="Code"
                             prefWidth="120"/>

                <TableColumn fx:id="colDescription"
                             text="Description"
                             prefWidth="250"/>

                <TableColumn fx:id="colCategory"
                             text="Category"
                             prefWidth="150"/>

                <TableColumn fx:id="colBrand"
                             text="Brand"
                             prefWidth="150"/>

                <TableColumn fx:id="colStock"
                             text="Stock"
                             prefWidth="100"/>

                <TableColumn fx:id="colUnit"
                             text="Unit"
                             prefWidth="100"/>

                <TableColumn fx:id="colAction"
                             text="Action"
                             prefWidth="120"/>

            </columns>

        </TableView>

    </center>

    <!-- ========================= BOTTOM ========================= -->

    <bottom>

        <HBox alignment="CENTER_RIGHT"
              spacing="10"
              style="-fx-padding:12 20;">

            <Label text="Records :"/>

            <Label fx:id="lblRecordCount"
                   text="0"/>

        </HBox>

    </bottom>

</BorderPane>
