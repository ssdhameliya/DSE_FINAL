<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.ItemMasterController"
            styleClass="page-root">

    <!-- ================= TOP ================= -->

    <top>

        <VBox spacing="18"
              styleClass="page-header">

            <HBox alignment="CENTER_LEFT"
                  spacing="15">

                <Label text="📦 Item Master"
                       styleClass="page-title"/>

                <Pane HBox.hgrow="ALWAYS"/>

                <TextField fx:id="txtSearch"
                           promptText="Search Item..."
                           prefWidth="260"
                           styleClass="search-field"/>

            </HBox>

            <HBox spacing="10"
                  styleClass="toolbar">

                <Button text="➕ New Item"
                        styleClass="primary-button"
                        onAction="#newItem"/>

                <Button text="✏ Edit"
                        onAction="#editItem"/>

                <Button text="🗑 Delete"
                        onAction="#deleteItem"/>

                <Button text="🔄 Refresh"
                        onAction="#refresh"/>

                <Button text="📥 Import"
                        onAction="#importItems"/>

                <Button text="📤 Export"
                        onAction="#exportItems"/>

            </HBox>

        </VBox>

    </top>

    <!-- ================= CENTER ================= -->

    <center>

        <StackPane styleClass="table-card">

            <TableView fx:id="tableItems" prefHeight="600" prefWidth="1200">
                <columns>

                    <TableColumn fx:id="colCode" text="Code" prefWidth="140"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="300"/>
                    <TableColumn fx:id="colCategory" text="Category" prefWidth="140"/>
                    <TableColumn fx:id="colBrand" text="Brand" prefWidth="120"/>
                    <TableColumn fx:id="colMaterial" text="Material" prefWidth="120"/>
                    <TableColumn fx:id="colSize" text="Size" prefWidth="100"/>
                    <TableColumn fx:id="colUnit" text="Unit" prefWidth="80"/>
                    <TableColumn fx:id="colHsn" text="HSN" prefWidth="100"/>
                    <TableColumn fx:id="colGst" text="GST %" prefWidth="90"/>
                    <TableColumn fx:id="colPurchasePrice" text="Purchase Price" prefWidth="120"/>
                    <TableColumn fx:id="colSellingPrice" text="Selling Price" prefWidth="120"/>
                    <TableColumn fx:id="colOpeningStock" text="Opening Stock" prefWidth="120"/>
                    <TableColumn fx:id="colMinimumStock" text="Minimum Stock" prefWidth="120"/>
                    <TableColumn fx:id="colLocation" text="Location" prefWidth="140"/>
                    <TableColumn fx:id="colRemarks" text="Remarks" prefWidth="240"/>
                    <TableColumn fx:id="colAction" text="Action" prefWidth="120"/>
                </columns>
            </TableView>



        </StackPane>

    </center>

    <!-- ================= BOTTOM ================= -->

    <bottom>

        <HBox spacing="8"
              alignment="CENTER_RIGHT"
              styleClass="status-bar">

            <Label text="Records"/>

            <Label fx:id="lblRecordCount"
                   styleClass="status-value"
                   text="0"/>

        </HBox>

    </bottom>

</BorderPane>
